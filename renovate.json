{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "npm:unpublishSafe",
    "schedule:daily",
    ":maintainLockFilesWeekly",
    ":disableDependencyDashboard",
    ":automergeMinor",
    ":automergePr",
    ":label(area: dependencies)"
  ],
  "prHourlyLimit": 20,
  "automergeType": "pr",
  "automergeStrategy": "squa"
}
